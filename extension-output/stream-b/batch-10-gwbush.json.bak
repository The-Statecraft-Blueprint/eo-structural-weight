      },
      {
        "flag_number": 9,
        "flag_name": "Second/Third-Order Effects",
        "status": "CRITICAL",
        "points": 2,
        "justification": "One of the most legally consequential and historically significant Faith-Based Initiative implementing orders: establishes detailed nondiscrimination/equal-access principles for religious organizations receiving federal social-service funds AND substantively broadens EO11246's religious-organization exemption from federal contractor nondiscrimination requirements - a durable expansion of religious organizations' participation in federal programs while retaining religious character, later the subject of extensive litigation and policy debate across subsequent administrations."
      },
      {
        "flag_number": 10,
        "flag_name": "Inter-Agency Cannibalization",
        "status": "ABSENT",
        "points": 0,
        "justification": "Sec.5(b)'s explicit OFBCI-coordination clause avoids competing claims."
      },
      {
        "flag_number": 11,
        "flag_name": "Exemptions Architecture",
        "status": "PRESENT",
        "points": 1,
        "justification": "Creates a detailed, structured exemption architecture distinguishing 'inherently religious activities' from federally-fundable services, with specific line-drawing rules (voluntary beneficiary participation, time/location separation) and an explicit religious-hiring exemption inserted into EO11246 (Sec.4, new Sec.204(c))."
      }
    ],

      },
      {
        "flag_number": 5,
        "flag_name": "Perverse Incentives",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - a nondiscrimination-policy order, no incentive-gaming structure at issue.",

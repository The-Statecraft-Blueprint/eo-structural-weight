  {
    "eo_number": "13201",
    "title": "Executive Order 13201—Notification of Employee Rights Concerning Payment of Union Dues or Fees",
    "date_signed": "2001-02-17",
    "president": "George W. Bush",
    "flags": [
      {
        "flag_number": 1,
        "flag_name": "Power Concentration",
        "status": "PRESENT",
        "points": 1,
        "justification": "The Secretary of Labor is granted broad administration, enforcement, and exemption authority over the entire federal-contractor 'Beck rights' notice regime."
      },
      {
        "flag_number": 2,
        "flag_name": "Accountability Gaps",
        "status": "ABSENT",
        "points": 0,
        "justification": "Genuine accountability mechanisms: agencies must report enforcement results back to the Secretary (Sec.7), and the Secretary must publish the names of noncomplying contractors (Sec.6(c)) - a real public-facing transparency measure."
      },
      {
        "flag_number": 3,
        "flag_name": "Bundling",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - single coherent subject (union-dues notice requirement)."
      },
      {
        "flag_number": 4,
        "flag_name": "Vague Enforcement",
        "status": "PRESENT",
        "points": 1,
        "justification": "Sec.3(a) permits the Secretary to exempt a contracting department or agency whenever 'special circumstances require... in order to serve the national interest' - the same undefined self-determined 'national interest' standard this stream has tracked since GHW Bush's EO12800 (this stream, Batch 8)."
      },
      {
        "flag_number": 5,
        "flag_name": "Perverse Incentives",
        "status": "PRESENT",
        "points": 1,
        "justification": "A genuinely self-interested veto embedded in the enforcement mechanism: a contracting-agency head can block a debarment or blacklisting directive against contracts under their own purview merely by 'continu[ing] personally to object' (Sec.6(a)-(b)) - the agency being investigated effectively holds veto power over its own enforcement.",
        "zombie_trap": false
      },
      {
        "flag_number": 6,
        "flag_name": "Sunset Provisions",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - an ongoing procurement-notice policy, no sunset expected."
      },
      {
        "flag_number": 7,
        "flag_name": "Preemption of Oversight",
        "status": "ABSENT",
        "points": 0,
        "justification": "No independent-oversight-blocking mechanism."
      },
      {
        "flag_number": 8,
        "flag_name": "Third-Party Incentive Gaps",
        "status": "ABSENT",
        "points": 0,
        "justification": "The order includes an affirmative government-litigation-support commitment (Sec.6(a) proviso) for contractors sued by subcontractors as a result of enforcement direction - a reasonably well-aligned third-party incentive structure."
      },
      {
        "flag_number": 9,
        "flag_name": "Second/Third-Order Effects",
        "status": "PRESENT",
        "points": 1,
        "justification": "Revives the identical notice requirement first imposed by GHW Bush's EO12800 (this stream, Batch 8) then revoked by Clinton's EO12836 (this stream: 16.67%) - continuing this stream's tracked cross-administration partisan reversal pattern on federal labor-relations orders."
      },
      {
        "flag_number": 10,
        "flag_name": "Inter-Agency Cannibalization",
        "status": "ABSENT",
        "points": 0,
        "justification": "A single Department of Labor administers the regime with no competing agency claims."
      },
      {
        "flag_number": 11,
        "flag_name": "Exemptions Architecture",
        "status": "PRESENT",
        "points": 1,
        "justification": "Sec.3(b)-(c) enumerate an extensive set of exemption categories: overseas work, state-law conflicts, non-union sites, worker-count thresholds, subcontract-tier thresholds, and facility-separateness carve-outs."
      }
    ],
    "applicable_count": 9,
    "raw_score": 5,
    "max_possible": 18,
    "normalized_score": 0.2778,
    "structural_weight_pct": 27.78,
    "critical_count": 0,
    "present_count": 5,
    "absent_count": 4,
    "na_count": 2,
    "dominant_flag": 1,
    "coder_id": "cowork-extension-stream-b",
    "coded_date": "2026-07-07",
    "notes": "Revives the Beck-rights federal-contractor union-dues notice requirement (reversing Clinton's EO12836, this stream: 16.67%), with Secretary of Labor administration, enforcement, and exemption authority. Scores 27.78% (5/18) - notable for a genuinely self-interested enforcement veto (Flag5: the contracting agency being investigated can block its own debarment directive by objecting), an undefined self-determined national-interest exemption standard (Flag4) continuing this stream's tracked EO12800 lineage, and an extensive exemptions architecture (Flag11) - substantially offset by real public-facing noncompliance-list transparency (Flag2 ABSENT)."
  },
  {
    "eo_number": "13202",

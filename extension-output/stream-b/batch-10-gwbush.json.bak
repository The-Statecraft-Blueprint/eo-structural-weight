  {
    "eo_number": "13198",
    "title": "Executive Order 13198—Agency Responsibilities With Respect to Faith-Based and Community Initiatives",
    "date_signed": "2001-01-29",
    "president": "George W. Bush",
    "flags": [
      {
        "flag_number": 1,
        "flag_name": "Power Concentration",
        "status": "PRESENT",
        "points": 1,
        "justification": "The White House Office of Faith-Based and Community Initiatives (established the same day by companion EO13199) coordinates and supervises five departmental Centers, with each Center's Director appointed only 'in consultation with' the White House OFBCI - a meaningful concentration of policy direction in a new EOP office."
      },
      {
        "flag_number": 2,
        "flag_name": "Accountability Gaps",
        "status": "PRESENT",
        "points": 1,
        "justification": "The mandated reports (180 days, then annually) run solely to the White House OFBCI - an internal executive-branch recipient, not Congress or the public."
      },
      {
        "flag_number": 3,
        "flag_name": "Bundling",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - single coherent subject (faith-based/community initiative coordination)."
      },
      {
        "flag_number": 4,
        "flag_name": "Vague Enforcement",
        "status": "PRESENT",
        "points": 1,
        "justification": "Core obligations are hedged throughout by 'to the extent permitted by law,' with no defined standard for what counts as an adequately identified 'barrier' or an adequate removal proposal."
      },

  {
    "eo_number": "13292",
    "title": "Executive Order 13292—Further Amendment to Executive Order 12958, as Amended, Classified National Security Information",
    "date_signed": "2003-03-25",
    "president": "George W. Bush",
    "flags": [
      {
        "flag_number": 1,
        "flag_name": "Power Concentration",
        "status": "CRITICAL",
        "points": 2,
        "justification": "Sec.1.7(c)-(d) permits RECLASSIFICATION of information 'after declassification and release to the public under proper authority' - an extraordinary, historically controversial power to reverse already-public disclosures, requiring only an agency-head-level written national-security determination - a genuinely rare and significant concentration of classification/reclassification authority with minimal external check."
      },
      {
        "flag_number": 2,
        "flag_name": "Accountability Gaps",
        "status": "PRESENT",
        "points": 1,
        "justification": "Sec.3.1(b)'s public-interest declassification 'balancing' determination is committed entirely to internal agency discretion and explicitly states it does 'not... create any substantive or procedural rights subject to judicial review' - a significant accountability gap for a decision with major public-transparency consequences."
      },
      {
        "flag_number": 3,
        "flag_name": "Bundling",
        "status": "PRESENT",
        "points": 1,
        "justification": "An enormous, comprehensive omnibus rewrite bundling original classification standards, derivative classification rules, declassification/automatic-declassification procedures, safeguarding and access rules, special access programs, sanctions, and the Interagency Security Classification Appeals Panel's structure - six major substantive Parts bundled into a single order governing the entire federal classification system."
      },
      {
        "flag_number": 4,
        "flag_name": "Vague Enforcement",
        "status": "PRESENT",
        "points": 1,
        "justification": "'Reasonably could be expected to cause damage to the national security' (Sec.1.1(a)(4)) is the foundational classification standard, inherently broad and self-determined by the classifying official, who need only 'identify or describe' the damage rather than externally prove it."
      },
      {
        "flag_number": 5,
        "flag_name": "Perverse Incentives",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - a classification-system order, no IEEPA-style incentive/emergency structure at issue.",
        "zombie_trap": false
      },
      {
        "flag_number": 6,
        "flag_name": "Sunset Provisions",
        "status": "PRESENT",
        "points": 1,
        "justification": "Default declassification duration extended to up to 25 years from the date of original classification (Sec.1.5(b)), with the automatic-declassification deadline for existing 25-year-old historical records delayed to December 31, 2006 (Sec.3.3(a)) - a genuine, substantively significant loosening of the declassification timeline compared to predecessor EO12958."
      },
      {
        "flag_number": 7,
        "flag_name": "Preemption of Oversight",
        "status": "CRITICAL",
        "points": 2,
        "justification": "Secs.3.1(a)-(b) and 5.3(e) systematically exclude judicial review of declassification 'public interest' balancing determinations and declare Interagency Panel decisions 'committed to the discretion of the Panel' - a multi-layered, government-wide preemption of external oversight over the entire classification/declassification apparatus."
      },
      {
        "flag_number": 8,
        "flag_name": "Third-Party Incentive Gaps",
        "status": "NOT_APPLICABLE",
        "points": null,
        "justification": "Not applicable - a classification-system order, not a third-party grant/incentive program."
      },
      {
        "flag_number": 9,
        "flag_name": "Second/Third-Order Effects",
        "status": "CRITICAL",
        "points": 2,
        "justification": "One of the most historically significant and controversial orders in the entire corpus: a comprehensive rewrite of the classification system governing all federal national-security information, widely criticized at the time by historians, journalists, and transparency advocates for reversing several Clinton-era EO12958 (not stream-b-scored; other coders: 4.55%-31.82%) pro-disclosure reforms - permitting reclassification of released information, extending default classification duration, and delaying automatic declassification - a landmark, government-wide transparency-policy reversal that remained in effect until Obama's EO13526 in 2009."
      },
      {
        "flag_number": 10,
        "flag_name": "Inter-Agency Cannibalization",
        "status": "ABSENT",
        "points": 0,
        "justification": "Sec.6.2 preserves the Atomic Energy Act/National Security Act frameworks intact; a single coherent classification-authority structure."
      },
      {
        "flag_number": 11,
        "flag_name": "Exemptions Architecture",
        "status": "PRESENT",
        "points": 1,
        "justification": "Part 4 creates elaborate, structured exemption categories, including Sec.4.4's waiver of need-to-know requirements for historical researchers and former senior Presidential/Vice-Presidential appointees, alongside nine itemized automatic-declassification exemption grounds (Sec.3.3(b))."
      }
    ],
    "applicable_count": 9,
    "raw_score": 11,
    "max_possible": 18,
    "normalized_score": 0.6111,
    "structural_weight_pct": 61.11,
    "critical_count": 3,
    "present_count": 5,
    "absent_count": 1,
    "na_count": 2,
    "dominant_flag": 1,
    "coder_id": "cowork-extension-stream-b",
    "coded_date": "2026-07-07",
    "notes": "A comprehensive rewrite of the federal government's uniform classification system (originally EO12958, not stream-b-scored; other coders: 4.55%-31.82%), permitting reclassification of previously-released information, extending default classification duration to 25 years, and delaying automatic declassification of historical records. Scores 61.11% (11/18) - among the highest-scoring orders in this stream's entire corpus - with THREE CRITICAL findings: an extraordinary reclassification-of-released-information power (Flag1), systematic multi-layered exclusion of judicial review over the entire declassification apparatus (Flag7), and landmark historical significance as a widely-criticized reversal of Clinton-era transparency reforms that remained in effect until Obama's 2009 EO13526 (Flag9) - a genuine diff-aware WEAKENING finding on the scale of EO13233's Presidential Records Act reversal (this batch, Chunk 3: 64.29%), together forming this administration's two most consequential government-transparency rollbacks."
  },

      },
      {
        "flag_number": 3,
        "flag_name": "Bundling",
        "status": "PRESENT",
        "points": 1,
        "justification": "Bundles a broad government-wide social-service nondiscrimination and religious-accommodation policy WITH a substantive amendment to EO11246's federal-contractor religious-organization exemption (Sec.4) - two structurally distinct legal mechanisms (grant/social-service-program guidance and federal-contractor exemption expansion) combined in a single order."
      },
      {
        "flag_number": 4,
        "flag_name": "Vague Enforcement",
        "status": "PRESENT",
